## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# WPF / XAML specific
*.g.cs
*.g.i.cs
*.baml
Generated_Code/

# SQLite databases (AI Study Hub uses SQLite)
# Nếu bạn cần giữ database mẫu, hãy commit file đó trước hoặc đổi tên file mẫu thành db.sample
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# NuGet Packages
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ReSharper / JetBrains Rider
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/
*.sln.iml

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Rider / Visual Studio Code
.vscode/
.agents/AGENTS.md
/.agents
