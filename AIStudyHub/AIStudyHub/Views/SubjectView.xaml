<UserControl x:Class="AIStudyHub.Views.SubjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AIStudyHub.ViewModels">

    <!-- Ráp ViewModel vào View -->
    <UserControl.DataContext>
        <vm:SubjectViewModel />
    </UserControl.DataContext>

    <Grid Margin="24"><ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel>

            <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,16">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Quản Lý Môn Học" Style="{StaticResource H1Style}"/>
                    <TextBlock Text="Thêm, sửa, xóa và theo dõi tiến độ các môn học của bạn" 
                               Style="{StaticResource BodyStyle}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Thêm Môn Học Mới" Style="{StaticResource H2Style}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tên môn:" Style="{StaticResource BodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Width="200" Margin="0,0,20,0" Padding="8,4" 
                                 Text="{Binding SubjectName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Mã môn:" Style="{StaticResource BodyStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Width="100" Margin="0,0,20,0" Padding="8,4" 
                                 Text="{Binding CourseCode, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Content="+ Thêm Môn" Style="{StaticResource PrimaryButtonStyle}" 
                                Command="{Binding AddSubjectCommand}" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Danh Sách Môn Học" Style="{StaticResource H2Style}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardStyle}" Padding="10">
                <DataGrid ItemsSource="{Binding Subjects}" 
                          RowEditEnding="DataGrid_RowEditEnding"
                          AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0" MinHeight="250">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã Môn" Binding="{Binding CourseCode}" Width="150"/>
                        <DataGridTextColumn Header="Tên Môn Học" Binding="{Binding Name}" Width="*"/>

                        <!-- Nút Xóa -->
                        <DataGridTemplateColumn Header="Hành động" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Xóa" 
                                            Command="{Binding DataContext.DeleteSubjectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" 
                                            Padding="8,4" FontSize="11" Background="#FFEbee" Foreground="#D32F2F" BorderThickness="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer></Grid>
</UserControl>
