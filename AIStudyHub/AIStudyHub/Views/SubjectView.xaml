<UserControl x:Class="AIStudyHub.Views.SubjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AIStudyHub.ViewModels"
             Background="White">

    <!-- Ráp ViewModel vào View -->
    <UserControl.DataContext>
        <vm:SubjectViewModel />
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Quản Lý Môn Học" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Form Thêm Môn Học -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Tên môn:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="200" Margin="0,0,15,0" Text="{Binding SubjectName, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Mã môn:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="100" Margin="0,0,15,0" Text="{Binding CourseCode, UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="Thêm Môn" Command="{Binding AddSubjectCommand}" Width="100" Padding="5"/>
        </StackPanel>

        <!-- Bảng danh sách Môn Học -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Subjects}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#F0F0F0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Môn" Binding="{Binding CourseCode}" Width="100"/>
                <DataGridTextColumn Header="Tên Môn Học" Binding="{Binding Name}" Width="*"/>

                <!-- Nút Xóa -->
                <DataGridTemplateColumn Header="Hành động" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Xóa" 
                                    Command="{Binding DataContext.DeleteSubjectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                    CommandParameter="{Binding}" 
                                    Background="#FF4C4C" Foreground="White" BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
