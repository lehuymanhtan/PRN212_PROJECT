<UserControl x:Class="AIStudyHub.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,20">
        <StackPanel>

            <!-- Page Title -->
            <TextBlock Text="Dashboard Overview (Classic View)" Style="{StaticResource H1Style}" Margin="0,0,0,20"/>

            <!-- MY SUBJECTS SECTION -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Danh sách Môn học (Subjects)" Style="{StaticResource H2Style}"/>
                <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Content="+ Add Subject" Padding="12,6"/>
            </Grid>
            
            <Border Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,24">
                <!-- DataGrid chuẩn truyền thống, cực kỳ dễ chấm điểm Logic và Binding -->
                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0" MinHeight="150">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="Tên Môn Học" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Tiến Độ (%)" Binding="{Binding Progress}" Width="150"/>
                        <DataGridTextColumn Header="Giảng Viên" Binding="{Binding Teacher}" Width="200"/>
                        
                        <!-- Nút thao tác mẫu cho DataGrid -->
                        <DataGridTemplateColumn Header="Thao tác" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Sửa" Padding="8,4" FontSize="11" Margin="0,0,8,0"/>
                                        <Button Content="Xóa" Padding="8,4" FontSize="11" Background="#FFEbee" Foreground="#D32F2F" BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- DEADLINES & EXAMS SECTION -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Quản lý Lịch thi &amp; Deadline (Tasks)" Style="{StaticResource H2Style}"/>
                <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Content="+ Add Task" Padding="12,6"/>
            </Grid>

            <Border Style="{StaticResource CardStyle}" Padding="10">
                <!-- DataGrid chuẩn truyền thống -->
                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0" MinHeight="250">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Task ID" Binding="{Binding TaskId}" Width="80"/>
                        <DataGridTextColumn Header="Tên Công Việc/Kỳ Thi" Binding="{Binding TaskName}" Width="*"/>
                        <DataGridTextColumn Header="Môn Học" Binding="{Binding SubjectName}" Width="200"/>
                        <DataGridTextColumn Header="Hạn Chót (Deadline)" Binding="{Binding DueDate}" Width="180"/>
                        <DataGridTextColumn Header="Trạng Thái" Binding="{Binding Status}" Width="120"/>

                        <!-- Nút thao tác mẫu cho DataGrid -->
                        <DataGridTemplateColumn Header="Thao tác" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Sửa" Padding="8,4" FontSize="11" Margin="0,0,8,0"/>
                                        <Button Content="Xong" Padding="8,4" FontSize="11" Background="#E8F5E9" Foreground="#2E7D32" BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
