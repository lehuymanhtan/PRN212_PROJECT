<UserControl x:Class="AIStudyHub.Views.DocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AIStudyHub.ViewModels"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             IsVisibleChanged="UserControl_IsVisibleChanged"
             Background="#F8F9FB">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:DocumentViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Header & Filter Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Status message -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content Area (List vs PDF Viewer) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER TOOLBAR -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="#0E1B2E" Opacity="0.06" BlurRadius="12" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Kho Tài Liệu &amp; PDF Viewer" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Quản lý tài liệu học tập, đọc file PDF trực tiếp với phân trang và Zoom" 
                               FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Filter theo Môn học -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Lọc môn học:" VerticalAlignment="Center" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <ComboBox Width="180" ItemsSource="{Binding FilterSubjects}" 
                              SelectedItem="{Binding SelectedFilterSubject}"
                              DisplayMemberPath="Name" Padding="8,6"/>
                </StackPanel>

                <!-- Nút Upload File -->
                <Button Grid.Column="2" Command="{Binding UploadDocumentCommand}"
                        Cursor="Hand" Padding="16,10" Background="#3B82F6" Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0"/>
                                    <TextBlock Text="Thêm Tài Liệu PDF/Word" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- STATUS BAR -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="#64748B" FontStyle="Italic" Margin="4,0,0,8"/>

        <!-- 1. MÀN HÌNH DANH SÁCH TÀI LIỆU (Ẩn khi đang mở PDF Viewer) -->
        <Grid Grid.Row="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsViewerOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Background="White" CornerRadius="12" Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="#0E1B2E" Opacity="0.05" BlurRadius="12" ShadowDepth="2"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Documents}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          Background="Transparent" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                          RowHeight="50" HeadersVisibility="Column">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#475569"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <!-- Loại File (Badge) -->
                        <DataGridTemplateColumn Header="Định Dạng" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#EFF6FF" CornerRadius="6" Padding="8,4" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding FileType}" Foreground="#2563EB" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Tên Tài Liệu -->
                        <DataGridTextColumn Header="Tên Tài Liệu" Binding="{Binding Title}" Width="2*" FontWeight="SemiBold"/>

                        <!-- Môn Học -->
                        <DataGridTextColumn Header="Môn Học" Binding="{Binding Subject.Name}" Width="1.5*"/>

                        <!-- Ngày Upload -->
                        <DataGridTextColumn Header="Ngày Tải Lên" Binding="{Binding UploadedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>

                        <!-- Hành Động (Đọc PDF / Xóa) -->
                        <DataGridTemplateColumn Header="Hành Động" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="Mở / Đọc"
                                                Command="{Binding DataContext.OpenDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="12,6" Background="#10B981" Foreground="White" BorderThickness="0" Margin="0,0,8,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="{TemplateBinding Content}" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button Content="Xóa"
                                                Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Padding="10,6" Background="#EF4444" Foreground="White" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="{TemplateBinding Content}" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- 2. MÀN HÌNH TRÌNH ĐỌC PDF INTEGRATED (PDF VIEWER) -->
        <Grid Grid.Row="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsViewerOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- DOCUMENT TOOLBAR -->
            <Border Grid.Row="0" Background="#1E293B" CornerRadius="10" Padding="16,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Quay lại -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Tên tài liệu -->
                        <ColumnDefinition Width="*"/>
                        <!-- Chú thích hỗ trợ bôi đen & cuộn trang -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding CloseViewerCommand}" 
                            Padding="14,8" Background="#334155" Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="← Đóng Tài Liệu" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Grid.Column="1" Text="{Binding CurrentTitle}" 
                               Foreground="White" FontWeight="Bold" FontSize="15" 
                               VerticalAlignment="Center" Margin="16,0"/>

                    <Border Grid.Column="2" Background="#0F172A" CornerRadius="6" Padding="12,6">
                        <TextBlock Text="💡 Cuộn xem toàn bộ các trang &amp; Bôi đen chọn chữ Copy (Ctrl + C)" 
                                   Foreground="#38BDF8" FontWeight="SemiBold" FontSize="13"/>
                    </Border>
                </Grid>
            </Border>

            <!-- DOCUMENT DISPLAY SURFACE -->
            <Border Grid.Row="1" Background="#CBD5E1" CornerRadius="10" Padding="4">
                <wv2:WebView2 x:Name="DocumentWebView" Source="{Binding CurrentViewerUrl}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
