<UserControl x:Class="AIStudyHub.Views.FlashcardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:AIStudyHub.Views"
             xmlns:viewmodels="clr-namespace:AIStudyHub.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <Button Content="← Back" Command="{Binding BackToDecksCommand}" HorizontalAlignment="Left" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="Indigo" FontSize="16" Cursor="Hand"/>
            <TextBlock Text="Flashcards Review" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Content="Queue 📋" Command="{Binding ToggleSidebarCommand}" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="Indigo" FontSize="16" Cursor="Hand" ToolTip="Toggle review queue"/>
        </Grid>
        
        <!-- Card Container -->
        <Border Grid.Row="1" Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="10" Padding="20" Margin="50" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Height="250" Cursor="Hand">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding FlipCardCommand}" />
            </Border.InputBindings>
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="10" Opacity="0.5" />
            </Border.Effect>
            
            <Grid>
                <TextBlock Text="{Binding CurrentCard.FrontText}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentCard}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding CurrentCard.BackText}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="No more cards to review!" FontSize="20" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentCard}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Rating Actions (Visible only when flipped) -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <Button Content="Blackout (0)" Command="{Binding RateCardCommand}" Margin="5" Width="90">
                <Button.CommandParameter>
                    <sys:Int32>0</sys:Int32>
                </Button.CommandParameter>
            </Button>
            <Button Content="Wrong (1)" Command="{Binding RateCardCommand}" Margin="5" Width="90">
                <Button.CommandParameter>
                    <sys:Int32>1</sys:Int32>
                </Button.CommandParameter>
            </Button>
            <Button Content="Hard (2)" Command="{Binding RateCardCommand}" Margin="5" Width="90">
                <Button.CommandParameter>
                    <sys:Int32>2</sys:Int32>
                </Button.CommandParameter>
            </Button>
            <Button Content="Good (3)" Command="{Binding RateCardCommand}" Margin="5" Width="90">
                <Button.CommandParameter>
                    <sys:Int32>3</sys:Int32>
                </Button.CommandParameter>
            </Button>
            <Button Content="Easy (4)" Command="{Binding RateCardCommand}" Margin="5" Width="90">
                <Button.CommandParameter>
                    <sys:Int32>4</sys:Int32>
                </Button.CommandParameter>
            </Button>
            <Button Content="Perfect (5)" Command="{Binding RateCardCommand}" Margin="5" Width="90">
                <Button.CommandParameter>
                    <sys:Int32>5</sys:Int32>
                </Button.CommandParameter>
            </Button>
        </StackPanel>
        
        <TextBlock Grid.Row="4" Text="{Binding FeedbackMessage}" Foreground="Green" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="16"/>

        <!-- Forgotten Cards Sidebar -->
        <Border Grid.Column="1" Grid.Row="1" Grid.RowSpan="4" Margin="20,0,0,0" Width="250"
                Background="#FAFAFA" BorderBrush="LightGray" BorderThickness="1" CornerRadius="10" Padding="15"
                Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="To Review Again:" FontWeight="Bold" FontSize="16" Foreground="Indigo" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Button Content="✕" Command="{Binding ToggleSidebarCommand}" Background="Transparent" Foreground="Gray" BorderThickness="0" HorizontalAlignment="Right" FontSize="14" Width="24" Height="24" Cursor="Hand"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ForgottenCards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding FrontText}" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Floating Add Button -->
        <Button Grid.Row="0" Grid.RowSpan="5" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,20"
                Width="60" Height="60" Command="{Binding OpenAddCardModalCommand}" Background="Indigo" Foreground="White" BorderThickness="0"
                ToolTip="Add new card">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="30">
                        <TextBlock Text="+" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Modal Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="5" Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding IsAddCardModalOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="White" BorderBrush="LightGray" BorderThickness="1" CornerRadius="10" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                <Border.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="5" Opacity="0.5" />
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Add New Card" FontWeight="Bold" FontSize="18" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Content="✕" Command="{Binding CloseAddCardModalCommand}" Background="Transparent" Foreground="Gray" BorderThickness="0" HorizontalAlignment="Right" FontSize="16" Width="30" Height="30" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="Front Text:" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewFrontText, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto"/>
                    <TextBlock Text="Back Text:" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewBackText, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20" VerticalScrollBarVisibility="Auto"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CloseAddCardModalCommand}" Background="Transparent" Foreground="Gray" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                        <Button Content="Add Card" Command="{Binding AddFlashcardCommand}" Width="120" Height="35" Background="Indigo" Foreground="White" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                        <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
