<UserControl x:Class="AIStudyHub.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AIStudyHub.ViewModels">

    <UserControl.DataContext>
        <vm:SettingsViewModel />
    </UserControl.DataContext>

    <Grid Margin="24">
        <Border Style="{StaticResource CardStyle}" Padding="24" MaxWidth="600" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Cài Đặt Hệ Thống" Style="{StaticResource H1Style}" Margin="0,0,0,16"/>

                <TextBlock Text="Cấu hình AI (Gemini / OpenAI Compatible)" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                
                <TextBlock Text="API Endpoint" Margin="0,8,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}" Padding="10" 
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="White"/>

                <TextBlock Text="API Key" Margin="0,16,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Padding="10"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="White"/>

                <TextBlock Text="AI Model" Margin="0,16,0,4" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}" Padding="10"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="White"/>

                <Button Content="Lưu Cài Đặt" Command="{Binding SaveSettingsCommand}" 
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,24,0,0" Width="150" HorizontalAlignment="Left"/>
                
                <Separator Margin="0,32,0,16" Background="{StaticResource BorderBrush}"/>

                <TextBlock Text="Thông tin Ứng dụng" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Tên ứng dụng: " Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="AI Study Hub" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Phiên bản: " Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="1.0.0 (MVP)" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Nhóm phát triển: " Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="PRN212 Project Group" FontWeight="SemiBold"/>
                </StackPanel>
                
                <TextBlock Text="Bản quyền © 2026. Mọi quyền được bảo lưu." Foreground="{StaticResource BorderBrush}" FontSize="12" Margin="0,24,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
