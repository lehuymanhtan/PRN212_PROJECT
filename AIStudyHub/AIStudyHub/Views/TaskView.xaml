<UserControl x:Class="AIStudyHub.Views.TaskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AIStudyHub.ViewModels"
             xmlns:conv="clr-namespace:AIStudyHub.Converters"
             Background="#F1F5F9">

    <!-- Ráp ViewModel vào View theo chuẩn MVVM -->
    <UserControl.DataContext>
        <vm:TaskViewModel />
    </UserControl.DataContext>

    <!-- Khai báo Resource Converters -->
    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToBorderColorConverter x:Key="StatusToBorderColor"/>
        <conv:TypeToIconConverter x:Key="TypeToIcon"/>
        <conv:TypeToTagColorConverter x:Key="TypeToTagColor"/>
        <conv:DueDateToUrgencyColorConverter x:Key="DueDateToUrgencyColor"/>
        <conv:DueDateToCountdownConverter x:Key="DueDateToCountdown"/>
        <conv:NullableDateToStringConverter x:Key="NullableDateToString"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:IsOverdueConverter x:Key="IsOverdue"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Stats Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Filter Bar -->
            <RowDefinition Height="*"/>
            <!-- Kanban Board -->
        </Grid.RowDefinitions>

        <!-- ================================================================== -->
        <!-- HEADER - Tiêu đề + Đồng hồ thời gian thực + Nút thêm             -->
        <!-- ================================================================== -->
        <Border Grid.Row="0" Background="#1E293B" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📅 Quản lý Deadline &amp; Lịch thi"
                               FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding CurrentDateTime}"
                               FontSize="13" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="+ Thêm Task"
                        Command="{Binding OpenAddFormCommand}"
                        Background="#3B82F6" Foreground="White"
                        FontSize="14" FontWeight="SemiBold"
                        Padding="20,10" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3B82F6"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- ================================================================== -->
        <!-- STATS BAR - Dashboard thống kê nhanh                               -->
        <!-- ================================================================== -->
        <Border Grid.Row="1" Background="#0F172A" Padding="24,12">
            <UniformGrid Columns="5" HorizontalAlignment="Left">
                <!-- Todo -->
                <Border Background="#1E3A5F" CornerRadius="8" Padding="16,10" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding CountTodo}" FontSize="28" FontWeight="Bold"
                                   Foreground="#60A5FA" HorizontalAlignment="Center"/>
                        <TextBlock Text="Chưa làm" FontSize="12" Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- InProgress -->
                <Border Background="#3D2B00" CornerRadius="8" Padding="16,10" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding CountInProgress}" FontSize="28" FontWeight="Bold"
                                   Foreground="#FBBF24" HorizontalAlignment="Center"/>
                        <TextBlock Text="Đang làm" FontSize="12" Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- Done -->
                <Border Background="#052E16" CornerRadius="8" Padding="16,10" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding CountDone}" FontSize="28" FontWeight="Bold"
                                   Foreground="#4ADE80" HorizontalAlignment="Center"/>
                        <TextBlock Text="Hoàn thành" FontSize="12" Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- Overdue -->
                <Border Background="#450A0A" CornerRadius="8" Padding="16,10" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{Binding CountOverdue}" FontSize="28" FontWeight="Bold"
                                   Foreground="#F87171" HorizontalAlignment="Center"/>
                        <TextBlock Text="Quá hạn ⚠" FontSize="12" Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- Due Soon -->
                <Border Background="#431407" CornerRadius="8" Padding="16,10">
                    <StackPanel>
                        <TextBlock Text="{Binding CountDueSoon}" FontSize="28" FontWeight="Bold"
                                   Foreground="#FB923C" HorizontalAlignment="Center"/>
                        <TextBlock Text="Sắp đến hạn 🔥" FontSize="12" Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- ================================================================== -->
        <!-- FILTER BAR - Bộ lọc trạng thái, loại, từ khoá, deadline gấp      -->
        <!-- ================================================================== -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tìm kiếm -->
                <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#CBD5E1"
                        BorderThickness="1" CornerRadius="6" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="14"/>
                        <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Padding="5,7"
                                 FontSize="13" Foreground="#475569">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Resources>
                                        <VisualBrush x:Key="PlaceholderBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="Tìm kiếm task..." Foreground="#94A3B8" FontSize="13"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Style.Resources>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Lọc theo Trạng thái -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="Trạng thái:" VerticalAlignment="Center" Margin="0,0,6,0"
                               FontSize="13" Foreground="#475569"/>
                    <ComboBox ItemsSource="{Binding FilterStatusOptions}"
                              SelectedItem="{Binding FilterStatus}"
                              Width="130" FontSize="13" VerticalContentAlignment="Center" Padding="8,4"/>
                </StackPanel>

                <!-- Lọc theo Loại -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="Loại:" VerticalAlignment="Center" Margin="0,0,6,0"
                               FontSize="13" Foreground="#475569"/>
                    <ComboBox ItemsSource="{Binding FilterTypeOptions}"
                              SelectedItem="{Binding FilterType}"
                              Width="130" FontSize="13" VerticalContentAlignment="Center" Padding="8,4"/>
                </StackPanel>

                <!-- Toggle hiển thị Urgent -->
                <Border Grid.Column="3" CornerRadius="6" Cursor="Hand" Margin="0,0,10,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderBrush" Value="#CBD5E1"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowUrgentOnly}" Value="True">
                                    <Setter Property="Background" Value="#FFF7ED"/>
                                    <Setter Property="BorderBrush" Value="#FB923C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Button Command="{Binding ShowUrgentFilterCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,6" Cursor="Hand">
                        <TextBlock FontSize="13" FontWeight="Medium">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🔥 Deadline gấp"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowUrgentOnly}" Value="True">
                                            <Setter Property="Foreground" Value="#EA580C"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Border>

                <!-- Nút Reset filter -->
                <Button Grid.Column="4" Content="↺ Xoá bộ lọc"
                        Command="{Binding ClearFiltersCommand}"
                        Background="#F1F5F9" Foreground="#475569"
                        FontSize="13" Padding="12,6" BorderBrush="#CBD5E1" BorderThickness="1"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ================================================================== -->
        <!-- KANBAN BOARD - 3 cột: Todo | InProgress | Done                     -->
        <!-- ================================================================== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CỘT 1: TODO -->
            <Border Grid.Column="0" Margin="16,16,8,16" Background="White"
                    BorderBrush="#DBEAFE" BorderThickness="1" CornerRadius="12">
                <DockPanel>
                    <!-- Header cột -->
                    <Border DockPanel.Dock="Top" Background="#EFF6FF" CornerRadius="12,12,0,0" Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#60A5FA" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Chưa làm" FontWeight="Bold" Foreground="#1E40AF" FontSize="15"/>
                            <Border Background="#DBEAFE" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                <TextBlock Text="{Binding CountTodo}" Foreground="#1E40AF" FontSize="12" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Danh sách task trong cột Todo -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <ItemsControl>
                            <ItemsControl.ItemsSource>
                                <Binding Path="AllTasks"/>
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl>
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Todo">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                        <!-- Kanban Card -->
                                        <Border Margin="0,0,0,10" Background="White" CornerRadius="8"
                                                BorderThickness="2,2,2,2" Padding="12"
                                                BorderBrush="{Binding DueDate, Converter={StaticResource DueDateToUrgencyColor}}">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Color="#000000" Opacity="0.06"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Type tag + Actions -->
                                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="4" Padding="6,2"
                                                            Background="{Binding Type, Converter={StaticResource TypeToTagColor}}">
                                                        <TextBlock FontSize="11" Foreground="White" FontWeight="SemiBold">
                                                            <Run Text="{Binding Type, Converter={StaticResource TypeToIcon}, Mode=OneWay}"/>
                                                            <Run Text="{Binding Type, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <!-- Edit + Delete buttons -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="✏" FontSize="12" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.OpenEditFormCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand" Padding="4,2" Foreground="#64748B"/>
                                                        <Button Content="🗑" FontSize="12" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand" Padding="4,2" Foreground="#EF4444"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Task Title -->
                                                <TextBlock Grid.Row="1" Text="{Binding Title}" FontWeight="SemiBold"
                                                           FontSize="14" Foreground="#1E293B" TextWrapping="Wrap"
                                                           Margin="0,0,0,4"/>

                                                <!-- Subject name -->
                                                <TextBlock Grid.Row="2" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6">
                                                    <Run Text="📚"/>
                                                    <Run Text="{Binding Subject.Name, FallbackValue='Không có môn'}"/>
                                                </TextBlock>

                                                <!-- DueDate countdown -->
                                                <Border Grid.Row="3" CornerRadius="4" Padding="6,3">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#F8FAFC"/>
                                                    </Border.Background>
                                                    <TextBlock FontSize="11" FontWeight="Medium"
                                                               Foreground="{Binding DueDate, Converter={StaticResource DueDateToUrgencyColor}}">
                                                        <Run Text="⏱"/>
                                                        <Run Text="{Binding DueDate, Converter={StaticResource NullableDateToString}}"/>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- CỘT 2: IN PROGRESS -->
            <Border Grid.Column="1" Margin="8,16,8,16" Background="White"
                    BorderBrush="#FEF3C7" BorderThickness="1" CornerRadius="12">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#FFFBEB" CornerRadius="12,12,0,0" Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#F59E0B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Đang làm" FontWeight="Bold" Foreground="#92400E" FontSize="15"/>
                            <Border Background="#FDE68A" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                <TextBlock Text="{Binding CountInProgress}" Foreground="#92400E" FontSize="12" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <ItemsControl>
                            <ItemsControl.ItemsSource>
                                <Binding Path="AllTasks"/>
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl>
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                        <Border Margin="0,0,0,10" Background="White" CornerRadius="8"
                                                BorderThickness="2,2,2,2" Padding="12"
                                                BorderBrush="{Binding DueDate, Converter={StaticResource DueDateToUrgencyColor}}">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="2" BlurRadius="6" Color="#000000" Opacity="0.06"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="4" Padding="6,2"
                                                            Background="{Binding Type, Converter={StaticResource TypeToTagColor}}">
                                                        <TextBlock FontSize="11" Foreground="White" FontWeight="SemiBold">
                                                            <Run Text="{Binding Type, Converter={StaticResource TypeToIcon}, Mode=OneWay}"/>
                                                            <Run Text="{Binding Type, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="✏" FontSize="12" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.OpenEditFormCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand" Padding="4,2" Foreground="#64748B"/>
                                                        <Button Content="🗑" FontSize="12" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand" Padding="4,2" Foreground="#EF4444"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Grid.Row="1" Text="{Binding Title}" FontWeight="SemiBold"
                                                           FontSize="14" Foreground="#1E293B" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                <TextBlock Grid.Row="2" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6">
                                                    <Run Text="📚"/>
                                                    <Run Text="{Binding Subject.Name, FallbackValue='Không có môn'}"/>
                                                </TextBlock>
                                                <Border Grid.Row="3" CornerRadius="4" Padding="6,3" Background="#F8FAFC">
                                                    <TextBlock FontSize="11" FontWeight="Medium"
                                                               Foreground="{Binding DueDate, Converter={StaticResource DueDateToUrgencyColor}}">
                                                        <Run Text="⏱"/>
                                                        <Run Text="{Binding DueDate, Converter={StaticResource NullableDateToString}}"/>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- CỘT 3: DONE -->
            <Border Grid.Column="2" Margin="8,16,16,16" Background="White"
                    BorderBrush="#DCFCE7" BorderThickness="1" CornerRadius="12">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F0FDF4" CornerRadius="12,12,0,0" Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Hoàn thành" FontWeight="Bold" Foreground="#14532D" FontSize="15"/>
                            <Border Background="#BBF7D0" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                <TextBlock Text="{Binding CountDone}" Foreground="#14532D" FontSize="12" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <ItemsControl>
                            <ItemsControl.ItemsSource>
                                <Binding Path="AllTasks"/>
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentControl>
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                        <Border Margin="0,0,0,10" Background="#F0FDF4" CornerRadius="8"
                                                BorderThickness="1" Padding="12" BorderBrush="#86EFAC" Opacity="0.85">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="1" BlurRadius="4" Color="#000000" Opacity="0.04"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="4" Padding="6,2"
                                                            Background="{Binding Type, Converter={StaticResource TypeToTagColor}}">
                                                        <TextBlock FontSize="11" Foreground="White" FontWeight="SemiBold">
                                                            <Run Text="{Binding Type, Converter={StaticResource TypeToIcon}, Mode=OneWay}"/>
                                                            <Run Text="{Binding Type, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="↩" FontSize="12" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.MoveTaskStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand" Padding="4,2" Foreground="#22C55E"
                                                                ToolTip="Chuyển lại trạng thái"/>
                                                        <Button Content="🗑" FontSize="12" Background="Transparent" BorderThickness="0"
                                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand" Padding="4,2" Foreground="#EF4444"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Grid.Row="1" Text="{Binding Title}" FontWeight="SemiBold"
                                                           FontSize="14" Foreground="#374151" TextWrapping="Wrap"
                                                           TextDecorations="Strikethrough" Margin="0,0,0,4"/>
                                                <TextBlock Grid.Row="2" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6">
                                                    <Run Text="📚"/>
                                                    <Run Text="{Binding Subject.Name, FallbackValue='Không có môn'}"/>
                                                </TextBlock>
                                                <TextBlock Grid.Row="3" Text="✅ Đã hoàn thành" FontSize="11"
                                                           Foreground="#22C55E" FontWeight="Medium"/>
                                            </Grid>
                                        </Border>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ================================================================== -->
        <!-- OVERLAY FORM - Dialog thêm/sửa Task (hiện khi IsFormOpen = true)  -->
        <!-- ================================================================== -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              Visibility="{Binding IsFormOpen, Converter={StaticResource BoolToVisibility}}">
            <!-- Overlay mờ phía sau -->
            <Border Background="#000000" Opacity="0.45"/>

            <!-- Dialog card -->
            <Border Background="White" CornerRadius="16" Width="520"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="32">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="40" Color="#000000" Opacity="0.25"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Tiêu đề dialog -->
                    <Grid Margin="0,0,0,24">
                        <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#0F172A">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✏ Sửa Task"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                            <Setter Property="Text" Value="➕ Thêm Task mới"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button HorizontalAlignment="Right" Content="✕" Background="Transparent"
                                BorderThickness="0" FontSize="18" Foreground="#94A3B8"
                                Command="{Binding CloseFormCommand}" Cursor="Hand"/>
                    </Grid>

                    <!-- Tên task -->
                    <TextBlock Text="Tên Task *" FontSize="13" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,6"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                        <TextBox Text="{Binding FormTitle, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Padding="12,10" FontSize="14" Background="Transparent"/>
                    </Border>

                    <!-- Mô tả -->
                    <TextBlock Text="Mô tả" FontSize="13" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,6"/>
                    <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                        <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Padding="12,10" FontSize="13" Background="Transparent"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" MaxHeight="100"/>
                    </Border>

                    <!-- Môn học + Loại Task (2 cột) -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Môn học *" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#374151" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Subjects}"
                                      SelectedItem="{Binding FormSubject}"
                                      DisplayMemberPath="Name"
                                      Padding="8,8" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Loại Task *" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#374151" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TypeOptions}"
                                      SelectedItem="{Binding FormType}"
                                      Padding="8,8" FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- Deadline + Trạng thái (2 cột) -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Deadline" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#374151" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding FormDueDate}"
                                        FontSize="13" Padding="8,6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Trạng thái" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#374151" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding FormStatus}"
                                      Padding="8,8" FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- Countdown preview (nếu đang sửa) -->
                    <Border Background="#F0FDF4" CornerRadius="8" Padding="12,8" Margin="0,0,0,24"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding SelectedTaskCountdown}" FontSize="13"
                                   Foreground="#16A34A" FontWeight="Medium" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Huỷ" Command="{Binding CloseFormCommand}"
                                Background="#F1F5F9" Foreground="#475569" FontSize="14"
                                FontWeight="SemiBold" Padding="0,12" BorderThickness="1" BorderBrush="#CBD5E1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" Command="{Binding SaveTaskCommand}"
                                Background="#3B82F6" Foreground="White" FontSize="14"
                                FontWeight="SemiBold" Padding="0,12" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="💾 Lưu Task"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                            <Setter Property="Content" Value="➕ Thêm Task"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
