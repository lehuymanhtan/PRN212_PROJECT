<Window x:Class="AIStudyHub.Views.SubjectSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn Môn Học" Height="190" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F8F9FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Vui lòng chọn môn học cho tài liệu này:" 
                   FontWeight="SemiBold" FontSize="14" Foreground="#1E293B" Margin="0,0,0,12"/>

        <ComboBox x:Name="SubjectComboBox" Grid.Row="1" Height="36" Padding="8,4" FontSize="14"
                  DisplayMemberPath="Name">
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding" Value="8,6"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,16,0,0">
            <Button Content="Hủy" Click="CancelButton_Click" IsCancel="True"
                    Width="80" Height="32" Margin="0,0,10,0" Background="#64748B" Foreground="White" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Xác nhận" Click="SelectButton_Click" IsDefault="True" FontWeight="Bold"
                    Width="100" Height="32" Background="#2563EB" Foreground="White" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
