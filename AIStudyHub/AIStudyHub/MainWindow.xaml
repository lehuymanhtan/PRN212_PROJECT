<Window x:Class="AIStudyHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIStudyHub.Views"
        xmlns:vm="clr-namespace:AIStudyHub.ViewModels"
        Title="AI Study Hub - Trợ Lý Học Tập &amp; Quản Lý Tài Liệu Số" 
        Height="760" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar menu -->
            <ColumnDefinition Width="260"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR MENU -->
        <Border Grid.Column="0" Background="#0F172A">
            <Grid Margin="16,24,16,20">
                <Grid.RowDefinitions>
                    <!-- Header Logo & Name -->
                    <RowDefinition Height="Auto"/>
                    <!-- Navigation items -->
                    <RowDefinition Height="*"/>
                    <!-- Footer info -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="8,0,8,28">
                    <TextBlock Text="AI STUDY HUB" FontSize="20" FontWeight="Black" Foreground="White"/>
                    <TextBlock Text="Trợ lý học tập thông minh" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Navigation Buttons (RadioButtons styled as modern menu items) -->
                <StackPanel Grid.Row="1">
                    <StackPanel.Resources>
                        <Style TargetType="RadioButton">
                            <Setter Property="GroupName" Value="SidebarMenu"/>
                            <Setter Property="Height" Value="48"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="8" Padding="14,10">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1E293B"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Nút 1: Quản lý Môn học -->
                    <RadioButton IsChecked="True" Command="{Binding ShowSubjectsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📚" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Quản Lý Môn Học" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Nút 2: Tài Liệu & PDF Viewer -->
                    <RadioButton Command="{Binding ShowDocumentsCommand}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📄" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Tài Liệu &amp; PDF Viewer" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Footer / Role Info -->
                <Border Grid.Row="2" Background="#1E293B" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Thành viên 4" Foreground="#38BDF8" FontWeight="Bold" FontSize="12"/>
                        <TextBlock Text="Quản lý Tài liệu &amp; PDF Viewer" Foreground="#E2E8F0" FontSize="12" Margin="0,2,0,0"/>
                        <TextBlock Text="NET 8.0 WPF • PdfiumViewer" Foreground="#64748B" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA (TabControl ẩn header để chuyển màn hình lập tức) -->
        <Grid Grid.Column="1" Background="#F8F9FB">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}" 
                        Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- Tab 0: Quản Lý Môn Học -->
                <TabItem>
                    <views:SubjectView />
                </TabItem>

                <!-- Tab 1: Tài Liệu & PDF Viewer -->
                <TabItem>
                    <views:DocumentView />
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
