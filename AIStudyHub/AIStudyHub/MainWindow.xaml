<Window x:Class="AIStudyHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIStudyHub.Views"
        xmlns:vm="clr-namespace:AIStudyHub.ViewModels"
        Title="AI Study Hub" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ========== SIDEBAR ========== -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,20,12,16">

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,0,28">
                    <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource PrimaryBrush}">
                        <TextBlock Text="📚" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="AI Study Hub" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Bottom: Study Session quick note -->
                <StackPanel DockPanel.Dock="Bottom">
                    <Separator Margin="0,0,0,12" Background="{StaticResource BorderBrush}"/>
                    <TextBlock Text="Quick Notes" Style="{StaticResource CaptionStyle}" Margin="8,0,0,6" FontWeight="SemiBold"/>
                    <Border Background="{StaticResource AppBgBrush}" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                        <TextBox BorderThickness="0" Background="Transparent" FontSize="12"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 Text="Type your study question..." TextWrapping="Wrap" Height="50"/>
                    </Border>
                    <TextBlock Text="Study Sessions" Style="{StaticResource CaptionStyle}" Margin="8,0,0,4" FontWeight="SemiBold"/>
                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱" FontSize="14"/>
                            <TextBlock Text="Start Focus Timer" Margin="8,0,0,0" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Nav Items -->
                <StackPanel>
                    <Button Style="{StaticResource NavButtonActiveStyle}" Margin="0,2" Command="{Binding NavigateToDashboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="16"/>
                            <TextBlock Text="Dashboard" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,2" Command="{Binding NavigateToSubjectsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎓" FontSize="14"/>
                            <TextBlock Text="My Subjects" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="14"/>
                            <TextBlock Text="Deadlines &amp; Exams" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" FontSize="14"/>
                            <TextBlock Text="PDF Reader" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButtonStyle}" Margin="0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧠" FontSize="14"/>
                            <TextBlock Text="Flashcards &amp; Notes" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <DockPanel Grid.Column="1" Margin="0">

            <!-- TOP BAR -->
            <Border DockPanel.Dock="Top" Background="{StaticResource SidebarBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Search -->
                    <Grid Grid.Column="0" MaxWidth="320" HorizontalAlignment="Left">
                        <TextBox Style="{StaticResource SearchBoxStyle}" Text="Search subjects, notes..."/>
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Grid>
                    <!-- User Info -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource NavButtonStyle}" Padding="8">
                            <TextBlock Text="🔔" FontSize="16"/>
                        </Button>
                        <Border Width="34" Height="34" CornerRadius="17" Background="{StaticResource PrimaryBrush}" Margin="8,0">
                            <TextBlock Text="V" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="John Doe" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN VIEW (DYNAMIC) -->
            <ContentControl Content="{Binding CurrentViewModel}" />

        </DockPanel>

        <!-- ========== FLOATING ACTION BUTTON (AI CHAT) ========== -->
        <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24"
                Width="56" Height="56" Padding="0"
                Command="{Binding ToggleChatCommand}"
                ToolTip="Open AI Study Assistant">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChatVisible}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="28">
                        <TextBlock Text="🤖" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- ========== AI CHAT PANEL ========== -->
        <Border Grid.Column="2" Background="{StaticResource SidebarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                Width="280"
                Visibility="{Binding IsChatVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel Margin="0">

                <!-- Chat Header -->
                <Border DockPanel.Dock="Top" Padding="16,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="56" Height="56" CornerRadius="28" Background="#EEF0FF" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="🤖" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="AI Study Assistant" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="(Aisha)" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <!-- Close Button -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                Background="Transparent" BorderThickness="0" 
                                Foreground="{StaticResource TextSecondaryBrush}" Padding="4"
                                Command="{Binding ToggleChatCommand}"
                                ToolTip="Close Chat">
                            <TextBlock Text="✕" FontSize="16" FontWeight="Bold"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Chat Input -->
                <Border DockPanel.Dock="Bottom" Padding="12,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource AppBgBrush}" CornerRadius="20" Padding="14,8">
                            <TextBox BorderThickness="0" Background="Transparent" FontSize="12"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     Text="Type your study question here..."/>
                        </Border>
                        <Button Grid.Column="1" Margin="8,0,0,0" Width="36" Height="36"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="0" Content="➤"
                                FontSize="14"/>
                    </Grid>
                </Border>

                <!-- Chat Messages -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                    <StackPanel>
                        <!-- AI Message -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="(Aisha)" Style="{StaticResource CaptionStyle}" Margin="0,0,0,2"/>
                            <Border Style="{StaticResource BubbleLeftStyle}">
                                <TextBlock Text="How can I help you today, John?" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                        <!-- User Message -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="(John)" Style="{StaticResource CaptionStyle}" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                            <Border Style="{StaticResource BubbleRightStyle}">
                                <TextBlock Text="Summarize the key points of Newton's Laws." FontSize="12" Foreground="White" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                        <!-- AI Reply -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="(Aisha)" Style="{StaticResource CaptionStyle}" Margin="0,0,0,2"/>
                            <Border Style="{StaticResource BubbleLeftStyle}">
                                <TextBlock Text="Certainly! Newton's first law states that an object in motion stays in motion unless acted upon by an external force..." FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
