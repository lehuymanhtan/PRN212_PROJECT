<Window x:Class="AIStudyHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIStudyHub.Views"
        Title="AI Study Hub" Height="600" Width="800">
    <Grid>
        <TabControl>
            <!-- Hiển thị màn hình Quản lý môn học -->
            <TabItem Header="Subjects">
                <views:SubjectView />
            </TabItem>
            <!-- Hiển thị màn hình Flashcards -->
            <TabItem Header="Flashcards">
                <views:FlashcardView />
            </TabItem>
            <!-- Hiển thị màn hình Annotations -->
            <TabItem Header="Annotations">
                <views:AnnotationView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
