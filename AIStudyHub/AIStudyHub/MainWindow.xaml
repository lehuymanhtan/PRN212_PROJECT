<Window x:Class="AIStudyHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIStudyHub.Views"
        Title="AI Study Hub" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Thanh điều hướng bên trái -->
            <ColumnDefinition Width="220"/>
            <!-- Nội dung chính -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================ -->
        <!-- SIDEBAR - Thanh điều hướng (Navigation)                      -->
        <!-- ============================================================ -->
        <Border Grid.Column="0" Background="#1E293B">
            <DockPanel>
                <!-- Logo App -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20" BorderBrush="#334155"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="🎓" FontSize="32" HorizontalAlignment="Center"/>
                        <TextBlock Text="AI Study Hub" FontSize="16" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        <TextBlock Text="v1.0.0" FontSize="11" Foreground="#64748B"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Menu Items -->
                <StackPanel DockPanel.Dock="Top" Margin="12,16,12,0">

                    <!-- Nút Quản lý Môn học (TV1) -->
                    <Button x:Name="btnSubject" Content="📚  Môn học"
                            Click="NavButton_Click" Tag="Subject"
                            HorizontalContentAlignment="Left" Padding="16,12"
                            Background="Transparent" Foreground="#94A3B8" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Nút Deadline &amp; Lịch thi (TV3) - Active mặc định -->
                    <Button x:Name="btnTask" Content="📅  Deadline &amp; Lịch thi"
                            Click="NavButton_Click" Tag="Task"
                            HorizontalContentAlignment="Left" Padding="16,12"
                            Background="#3B82F6" Foreground="White" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2563EB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Các module khác (placeholder) -->
                    <Button x:Name="btnDocument" Content="📄  Tài liệu PDF"
                            Click="NavButton_Click" Tag="Document"
                            HorizontalContentAlignment="Left" Padding="16,12"
                            Background="Transparent" Foreground="#94A3B8" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#334155"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="🤖  AI Assistant" HorizontalContentAlignment="Left"
                            Padding="16,12" Background="Transparent" Foreground="#64748B"
                            BorderThickness="0" FontSize="14" Cursor="Hand" Margin="0,2" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🃏  Flashcard" HorizontalContentAlignment="Left"
                            Padding="16,12" Background="Transparent" Foreground="#64748B"
                            BorderThickness="0" FontSize="14" Cursor="Hand" Margin="0,2" IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Version info ở dưới -->
                <Border DockPanel.Dock="Bottom" Padding="20,16" BorderBrush="#334155" BorderThickness="0,1,0,0">
                    <TextBlock Text="PRN212 Project - Team 6" FontSize="11"
                               Foreground="#475569" TextWrapping="Wrap"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- CONTENT AREA - Nội dung thay đổi theo navigation             -->
        <!-- ============================================================ -->
        <Border Grid.Column="1" x:Name="ContentArea">
            <!-- Mặc định hiển thị màn hình Deadline (Task View của TV3) -->
            <views:TaskView x:Name="taskViewControl"/>
        </Border>
    </Grid>
</Window>
